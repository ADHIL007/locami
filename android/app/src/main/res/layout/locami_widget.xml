<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Top Section -->
    <LinearLayout
        android:id="@+id/top_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentTop="true">

        <!-- Left Info Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCAMi"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Current Location Row with Icon -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_near_me"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.7" />

                <TextView
                    android:id="@+id/widget_current_loc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Finding location..."
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    android:singleLine="true"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_distance_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- km"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/widget_dest_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="to Destination"
                android:textColor="#88FFFFFF"
                android:textSize="10sp"
                android:layout_marginTop="1dp" />

            <TextView
                android:id="@+id/widget_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Waiting..."
                android:textColor="#4CAF50"
                android:textSize="9sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Right Speed Gauge (Bitmap Image) -->
        <ImageView
            android:id="@+id/widget_gauge_img"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="8dp"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <!-- Progress Bar Section -->
    <RelativeLayout
        android:id="@+id/progress_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/top_section"
        android:layout_marginTop="6dp">

        <ImageView
            android:id="@+id/widget_progress_img"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:scaleType="fitXY" />

        <TextView
            android:id="@+id/widget_alert_dist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert within 500m"
            android:textColor="#88FFFFFF"
            android:textSize="9sp"
            android:layout_below="@id/widget_progress_img"
            android:layout_marginTop="4dp" />
    </RelativeLayout>

    <!-- Unified Button Section -->
    <LinearLayout
        android:id="@+id/widget_button"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/widget_button_bg"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_button_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STOP ALERT"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </LinearLayout>

</RelativeLayout>
